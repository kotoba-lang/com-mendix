// Mendix clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace mendix {

    entity Flow {
        id: string @unique
        name: string
        trigger: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Step {
        id: string @unique
        flowId: string
        appName: string
        action: string
        position: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Connection {
        id: string @unique
        appName: string
        authType: string
        active: boolean
        createdAt: datetime
        updatedAt: datetime
    }

    entity Run {
        id: string @unique
        flowId: string
        status: string
        durationMs: integer
        startedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity App {
        id: string @unique
        name: string
        category: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Webhook {
        id: string @unique
        flowId: string
        url: string
        active: boolean
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
